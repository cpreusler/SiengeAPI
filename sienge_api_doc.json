  "modules": [
    {
      "module": "Clientes",
      "category": "CRM",
      "base_path": "/customers",
      "endpoints": [
        {
          "method": "GET",
          "path": "/customers",
          "description": "Lista clientes com paginação",
          "params": {
            "page": {
              "type": "integer",
              "required": false
            },
            "size": {
              "type": "integer",
              "required": false,
              "max": 200
            },
            "name": {
              "type": "string",
              "required": false
            },
            "document": {
              "type": "string",
              "required": false
            }
          },
          "response_fields": {
            "id": "integer",
            "name": "string",
            "document": "string",
            "email": "string",
            "phoneNumber": "string",
            "customerType": "string",
            "status": "string",
            "createdAt": "date-time"
          }
        },
        {
          "method": "POST",
          "path": "/customers",
          "description": "Cria novo cliente",
          "required_fields": [
            "name",
            "document",
            "customerType"
          ],
          "body_fields": {
            "name": "string",
            "document": "string",
            "customerType": "string",
            "email": "string",
            "phoneNumber": "string",
            "birthDate": "date",
            "civilStatus": "string",
            "profession": "string",
            "income": "number"
          }
        },
        {
          "method": "GET",
          "path": "/customers/{id}",
          "description": "Busca cliente por ID",
          "path_params": {
            "id": "integer"
          },
          "response_fields": {
            "id": "integer",
            "name": "string",
            "document": "string",
            "addresses": "array",
            "spouse": "object"
          }
        },
        {
          "method": "PATCH",
          "path": "/customers/{id}",
          "description": "Atualiza cliente",
          "path_params": {
            "id": "integer"
          },
          "body_fields": {
            "name": "string",
            "email": "string",
            "phoneNumber": "string"
          }
        }
      ]
    },
    {
      "module": "Credores",
      "category": "Financeiro",
      "base_path": "/creditors",
      "endpoints": [
        {
          "method": "POST",
          "path": "/creditors",
          "description": "Cria novo credor/fornecedor",
          "required_fields": [
            "name",
            "document",
            "creditorType"
          ],
          "body_fields": {
            "name": "string",
            "document": "string",
            "creditorType": "string",
            "fantasyName": "string",
            "email": "string",
            "phoneNumber": "string",
            "address": "string",
            "city": "string",
            "state": "string",
            "zipCode": "string"
          }
        },
        {
          "method": "GET",
          "path": "/creditors",
          "description": "Lista credores",
          "params": {
            "name": {
              "type": "string",
              "required": false
            },
            "document": {
              "type": "string",
              "required": false
            },
            "status": {
              "type": "string",
              "required": false
            }
          }
        },
        {
          "method": "POST",
          "path": "/creditors/{creditorId}/bank-informations",
          "description": "Adiciona conta bancária",
          "path_params": {
            "creditorId": "integer"
          },
          "required_fields": [
            "bank",
            "agency",
            "account"
          ],
          "body_fields": {
            "bank": "string",
            "agency": "string",
            "account": "string",
            "accountType": "string",
            "holderName": "string"
          }
        },
        {
          "method": "POST",
          "path": "/creditors/{creditorId}/pix-informations",
          "description": "Adiciona chave PIX",
          "path_params": {
            "creditorId": "integer"
          },
          "required_fields": [
            "pixKeyType",
            "pixKey"
          ],
          "body_fields": {
            "pixKeyType": "string",
            "pixKey": "string",
            "holderName": "string",
            "bank": "string"
          }
        }
      ]
    },
    {
      "module": "Títulos a Receber",
      "category": "Financeiro",
      "base_path": "/accounts-receivable",
      "endpoints": [
        {
          "method": "GET",
          "path": "/accounts-receivable",
          "description": "Lista títulos a receber",
          "params": {
            "customerId": {
              "type": "integer",
              "required": false
            },
            "dueDate": {
              "type": "date",
              "required": false
            },
            "status": {
              "type": "string",
              "required": false
            }
          },
          "response_fields": {
            "id": "integer",
            "customerId": "integer",
            "customerName": "string",
            "originalValue": "number",
            "currentValue": "number",
            "dueDate": "date",
            "status": "string"
          }
        }
      ]
    },
    {
      "module": "Estoque de Insumos",
      "category": "Suprimentos",
      "base_path": "/stock-inventories",
      "endpoints": [
        {
          "method": "GET",
          "path": "/stock-inventories/{costCenterId}/items",
          "description": "Lista itens em estoque",
          "path_params": {
            "costCenterId": "integer"
          },
          "response_fields": {
            "resourceId": "integer",
            "resourceName": "string",
            "quantity": "number",
            "unit": "string",
            "averageCost": "number",
            "totalValue": "number"
          }
        }
      ]
    },
    {
      "module": "Pedidos de Compra",
      "category": "Suprimentos",
      "base_path": "/purchase-orders",
      "endpoints": [
        {
          "method": "GET",
          "path": "/purchase-orders",
          "description": "Lista pedidos de compra",
          "params": {
            "creditorId": {
              "type": "integer",
              "required": false
            },
            "status": {
              "type": "string",
              "required": false
            },
            "createdFrom": {
              "type": "date",
              "required": false
            }
          }
        }
      ]
    }
